<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.shuang.module.agency.dal.mysql.AgencyUserMapper">

    <resultMap id="BaseResultMap" type="cn.shuang.module.agency.dal.dataobject.AgencyUserDO">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="parent_agency_id" property="parentAgencyId"/>
        <result column="level" property="level"/>
        <result column="agency_enabled" property="agencyEnabled"/>
        <result column="bind_mode" property="bindMode"/>
        <result column="total_points" property="totalPoints"/>
        <result column="distributed_points" property="distributedPoints"/>
        <result column="direct_invite_count" property="directInviteCount"/>
        <result column="team_total_count" property="teamTotalCount"/>
        <result column="agency_fee" property="agencyFee"/>
        <result column="pay_fee_time" property="payFeeTime"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <!-- 根据用户 ID 查询代理信息 -->
    <select id="selectByUserId" resultMap="BaseResultMap">
        SELECT * FROM agency_user
        WHERE user_id = #{userId}
        AND deleted = 0
        LIMIT 1
    </select>

    <!-- 根据上级代理 ID 查询下级列表 -->
    <select id="selectByParentAgencyId" resultMap="BaseResultMap">
        SELECT * FROM agency_user
        WHERE parent_agency_id = #{parentAgencyId}
        AND deleted = 0
    </select>

    <!-- 统计直推人数 -->
    <select id="countDirectInvite" resultType="Integer">
        SELECT COUNT(*) FROM agency_user
        WHERE parent_agency_id = #{userId}
        AND deleted = 0
    </select>

</mapper>
